{
  "name": "DriftID",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "ms-playwright.playwright",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/gpu-env/bin/python",
        "python.terminal.activateEnvironment": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.previewFlutterUiGuides": false,
        "[dart]": {
          "editor.formatOnSave": true,
          "editor.selectionHighlight": false,
          "editor.suggestSelection": "first"
        }
      }
    }
  },
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}",
    "CHROME_EXECUTABLE": "/usr/bin/chromium"
  },
  "postCreateCommand": "bash -lc 'source /opt/conda/etc/profile.d/conda.sh && conda activate gpu-env && python -c \"import torch, timm, faiss; print(\\\"Environment ready:\\\", torch.__version__)\"'; if command -v flutter >/dev/null; then flutter doctor; fi; if [ -f ui/package.json ]; then cd ui && flutter pub get && npm ci && npx playwright install chromium; fi"
}
